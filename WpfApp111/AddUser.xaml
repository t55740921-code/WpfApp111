<Window x:Class="WpfApp111.AddUser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp111"
        mc:Ignorable="d"
        Title="AddUser" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MinHeight="200" MinWidth="200">
            <Label Content="Логин"/>
            <TextBox x:Name="tbLogin" Margin="5"/>
            <Label Content="Логин"/>
            <TextBox x:Name="tbPassword" Margin="5"/>
            <Label Content="Роль"/>
            <ComboBox x:Name="cbRoles" Margin="5"/>
            <CheckBox x:Name="ckBan" Content="Блокировка пользователя" Margin="5"/>
            <Button Content="Добавить пользователя" Margin="5" Click="Button_AddClick"/>
        </StackPanel>
    </Grid>
</Window>
