<Page x:Class="WpfApp111.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp111"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="61*"/>
            <RowDefinition Height="14*"/>
        </Grid.RowDefinitions>
        <Button Content="Добавить" HorizontalAlignment="Left" Margin="10,21,0,0" Grid.Row="1" VerticalAlignment="Top" Height="32" Width="125" Click="Button_Click"/>
        <DataGrid x:Name="DtGrid" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Login}" Header="Логин" Width="*"/>
                <DataGridTextColumn Binding="{Binding Password}" Header="Пароль" Width="*"/>
                <DataGridTextColumn Binding="{Binding RoleID}" Header="Роль" Width="*"/>
                <DataGridTextColumn Binding="{Binding Blocked}" Header="Заблокирован" Width="*"/>
            </DataGrid.Columns>

        </DataGrid>
        <Button Content="Редактировать" HorizontalAlignment="Left" Margin="177,21,0,0" Grid.Row="1" VerticalAlignment="Top" Height="32" Width="125" Click="Button_Click_1"/>
        <Button Content="Удалить" HorizontalAlignment="Left" Margin="665,21,0,0" Grid.Row="1" VerticalAlignment="Top" Height="32" Width="125" Click="Button_Click_2"/>

    </Grid>
</Page>
