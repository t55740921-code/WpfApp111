<Window x:Class="WpfApp111.Autorization"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp111"
        mc:Ignorable="d"
        Title="Autorization" MinHeight="345" MinWidth="655" Height="350" Width="650">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="254*"/>
            <ColumnDefinition Width="401*"/>
        </Grid.ColumnDefinitions>
        <Label Content="Логин" HorizontalAlignment="Left" Margin="40,88,0,0" VerticalAlignment="Top"/>
        <Label Content="Пароль" HorizontalAlignment="Left" Margin="40,130,0,0" VerticalAlignment="Top"/>
        <Label Content="Собери капчу" HorizontalAlignment="Left" Margin="152,60,0,0" VerticalAlignment="Top" Grid.Column="1"/>
        <Button Content="Войти" HorizontalAlignment="Left" Margin="68,172,0,0" VerticalAlignment="Top" Height="21" Width="80" Click="Button_Click"/>
        <TextBox x:Name="TbLogin" HorizontalAlignment="Left" Margin="83,92,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="TbPass" HorizontalAlignment="Left" Margin="83,134,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <Border  Tag="1" Height="50" Width="50" Background="LightGray" AllowDrop="True" DragEnter="Border_DragEnter" DragLeave="Border_DragLeave" Drop="Border_Drop" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="145,108,0,0" Grid.Column="1" />
        <Border Tag="2" Height="50" Width="50" Background="LightGray" AllowDrop="True" DragEnter="Border_DragEnter" DragLeave="Border_DragLeave" Drop="Border_Drop" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="195,108,0,0" Grid.Column="1" />
        <Border Tag="3" Height="50" Width="50" Background="LightGray" AllowDrop="True" DragEnter="Border_DragEnter" DragLeave="Border_DragLeave" Drop="Border_Drop" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="145,158,0,0" Grid.Column="1" />
        <Border  Tag="4" Height="50" Width="50" Background="LightGray" AllowDrop="True" DragEnter="Border_DragEnter" DragLeave="Border_DragLeave" Drop="Border_Drop" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="195,158,0,0" Grid.Column="1"/>
        <Image x:Name="Image1" Tag="1" MouseMove="MouseMove_Click" Width="50" Height="50"  Source="/Resources/1.png" Stretch="Fill" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="205,233,0,0" Grid.Column="1"/>
        <Image x:Name="Image2" Tag="2" MouseMove="MouseMove_Click" Width="50" Height="50"  Source="/Resources/2.png" Stretch="Fill" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="170,233,0,0" Grid.Column="1"/>
        <Image x:Name="Image3" Tag="3" MouseMove="MouseMove_Click" Width="50" Height="50"  Source="/Resources/3.png" Stretch="Fill" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="95,247,0,0" Grid.Column="1"/>
        <Image x:Name="Image4" Tag="4" MouseMove="MouseMove_Click" Width="50" Height="50" Source="/Resources/4.png" Stretch="Fill" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="58,247,0,0" Grid.Column="1"/>

    </Grid>
</Window>
